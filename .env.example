# Aligned News Video Pipeline — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# ── Required ─────────────────────────────────────────────────────────────────

# Aligned News API key (get yours at https://alignednews.com/account)
ALIGNED_API_KEY=alnw_your_key_here

# HeyGen API key (get yours at https://app.heygen.com/settings?tab=apiKey)
HEYGEN_API_KEY=your_heygen_api_key_here

# Anthropic API key (get yours at https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Override Aligned News API base URL (default: https://alignednews.com)
# ALIGNED_API_URL=https://alignednews.com
